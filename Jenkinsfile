pipeline {
    agent any
    
    stages {
        stage('Checkout') {
            steps {
                echo "Checking out branch"
            }
        }
        
        stage('Build') {
            steps {
                echo "Building branch"
            }
        }
        
        stage('Test') {
            steps {
                echo "Running tests on branch"
            }
        }
    }
    
}
